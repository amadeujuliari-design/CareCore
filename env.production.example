DATABASE_URL=postgresql+asyncpg://USUARIO:SENHA@HOST:5432/DB
SECRET_KEY=troque-por-uma-chave-longa-aleatoria-com-mais-de-32-caracteres
# Chave separada para criptografar credenciais sensíveis do cofre dos conviventes.
# Gere outro valor longo e aleatório, diferente da SECRET_KEY.
CREDENCIAIS_CONVIVENTE_KEY=troque-por-outra-chave-longa-aleatoria
APP_ENV=production
CARECORE_AUTO_CREATE_TABLES=false
# Habilite somente se o cadastro público/self-service for uma decisão comercial.
CARECORE_ONBOARDING_PUBLICO=false
# Limite para registrar requisições lentas no log; use 0 para desativar.
CARECORE_SLOW_REQUEST_MS=2000
# Limite de chaves IP/e-mail mantidas em memória no rate limit de login.
CARECORE_LOGIN_MAX_CHAVES_CACHE=5000
# Recomendado em produção: Redis compartilhado para rate limit distribuído entre instâncias.
CARECORE_RATE_LIMIT_REDIS_URL=redis://USUARIO:SENHA@HOST:6379/0
# Opcional/recomendado: monitoramento de erros e performance. PII é desativado no código.
CARECORE_SENTRY_DSN=https://CHAVE@o000000.ingest.sentry.io/000000
CARECORE_SENTRY_TRACES_SAMPLE_RATE=0.05
# json em produção facilita integração com Railway/Datadog/Sentry/coletores.
CARECORE_LOG_FORMAT=json
CARECORE_LOG_LEVEL=INFO

# Origens do app que podem chamar a API em produção.
CARECORE_CORS_ORIGINS=https://app.carecoreplus.com.br

# Opcional: liberar previews da Vercel durante testes antes do domínio final.
# Exemplo genérico, ajuste para o domínio real do projeto na Vercel se for usar.
# CARECORE_CORS_ORIGIN_REGEX=^https://carecore-front-.*\.vercel\.app$

# Ative apenas para diagnostico temporario.
SQLALCHEMY_ECHO=false
