DATABASE_URL=sqlite+aiosqlite:///./carecore_local.db
SECRET_KEY=carecore_local_dev
# Opcional no ambiente local. Em produção, use uma chave própria e diferente da SECRET_KEY.
# CREDENCIAIS_CONVIVENTE_KEY=carecore_local_cofre_dev
# local | development | production — em production, SECRET_KEY não pode ser o padrão de desenvolvimento
APP_ENV=local
# true no ambiente local; em production, use Alembic e mantenha false
CARECORE_AUTO_CREATE_TABLES=true
# true no ambiente local para permitir cadastro inicial/self-service
CARECORE_ONBOARDING_PUBLICO=true
# Limite para registrar requisições lentas no log; use 0 para desativar.
CARECORE_SLOW_REQUEST_MS=2000
# Limite de chaves IP/e-mail mantidas em memória no rate limit de login.
CARECORE_LOGIN_MAX_CHAVES_CACHE=5000
# text no local; use json para facilitar coleta por serviços externos.
CARECORE_LOG_FORMAT=text
CARECORE_LOG_LEVEL=INFO