# Copie este arquivo para .env.snapshot (nao versionar).
# URL somente leitura do Postgres de producao (Supabase).
# Obtenha no painel Supabase ou via: fly ssh console -a carecoreplus-api -C "printenv DATABASE_URL"
#
# Use driver psycopg2 (o script normaliza asyncpg/postgres:// automaticamente).
SNAPSHOT_DATABASE_URL=postgresql+psycopg2://USUARIO:SENHA@HOST:5432/postgres?sslmode=require
