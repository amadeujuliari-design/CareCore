---
import { SITE } from '../config/site';

const nav = [
  { href: '/funcionalidades', label: 'Funcionalidades' },
  { href: '/guia/', label: 'Guia do sistema' },
  { href: '/contato', label: 'Contato' },
  { href: '/privacidade', label: 'Privacidade' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-3" aria-label="CareCore+ — página inicial">
      <img src="/logo.png" alt="" width="40" height="40" class="h-10 w-10 object-contain" />
      <span class="text-lg font-black tracking-wide text-slate-900">
        CARE<span class="text-brand-600">CORE+</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-semibold transition',
              currentPath === item.href || currentPath.startsWith(`${item.href}/`)
                ? 'text-brand-600'
                : 'text-slate-600 hover:text-brand-600',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={SITE.appUrl}
        class="btn-primary px-4 py-2 text-xs sm:px-6 sm:text-sm"
        rel="noopener noreferrer"
      >
        Entrar
      </a>
    </div>
  </div>

  <nav class="flex gap-1 overflow-x-auto border-t border-slate-100 px-4 py-2 md:hidden" aria-label="Principal mobile">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'whitespace-nowrap rounded-full px-3 py-1.5 text-xs font-semibold',
            currentPath === item.href
              ? 'bg-brand-soft text-brand-600'
              : 'text-slate-600',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
